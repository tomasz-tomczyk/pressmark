---
import type { HTMLAttributes } from "astro/types";

type Props = {
  dropcap?: boolean;
  class?: string;
} & HTMLAttributes<"article">;

const { dropcap = false, class: className, ...rest } = Astro.props as Props;
---

<article class:list={["prose-pressmark", { dropcap }, className]} {...rest}>
  <slot />
</article>
