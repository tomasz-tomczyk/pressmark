---
import type { HTMLAttributes } from "astro/types";

type Props = {
  value: number;
  class?: string;
} & HTMLAttributes<"div">;

const { value, class: className, ...rest } = Astro.props as Props;
const clamped = Math.max(0, Math.min(100, value));
---

<div
  class:list={["progress", className]}
  role="progressbar"
  aria-valuenow={clamped}
  aria-valuemin={0}
  aria-valuemax={100}
  {...rest}
>
  <div class="progress-fill" style={`width: ${clamped}%`}></div>
</div>
