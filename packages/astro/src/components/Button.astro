---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "secondary" | "link";

type Props = {
  variant?: Variant;
  as?: "button" | "a";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
} & (HTMLAttributes<"button"> | HTMLAttributes<"a">);

const {
  variant = "primary",
  as,
  href,
  type,
  class: className,
  ...rest
} = Astro.props as Props;

const Tag = as ?? (href ? "a" : "button");

const variantClass =
  variant === "link"
    ? "btn-link"
    : variant === "secondary"
      ? "btn btn-secondary"
      : "btn btn-primary";
---

{
  Tag === "a" ? (
    <a class:list={[variantClass, className]} href={href} {...(rest as HTMLAttributes<"a">)}>
      <slot />
    </a>
  ) : (
    <button class:list={[variantClass, className]} type={type ?? "button"} {...(rest as HTMLAttributes<"button">)}>
      <slot />
    </button>
  )
}
