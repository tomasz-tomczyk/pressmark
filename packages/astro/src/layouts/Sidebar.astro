---
export type SidebarItem = {
  href: string;
  label: string;
  /** Raw SVG inner content (paths, rects, circles). Rendered inside a 16×16 viewBox=0 0 24 24 wrapper. */
  icon?: string;
};

type Props = {
  brand?: string;
  brandHref?: string;
  items?: SidebarItem[];
  currentPath?: string;
  class?: string;
};

const {
  brand,
  brandHref = "/",
  items = [],
  currentPath = "/",
  class: className = "",
} = Astro.props as Props;

// Respect Astro's base path so library consumers at any base work.
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const withBase = (p: string): string => {
  if (!p) return p;
  if (p.startsWith("http") || p.startsWith("#")) return p;
  if (p === "/") return base + "/";
  if (p.startsWith("/")) return base + p;
  return p;
};

function norm(p: string): string {
  if (!p) return "";
  const withoutBase = base ? p.replace(new RegExp("^" + base), "") : p;
  const noHash = withoutBase.split("#")[0] ?? "";
  return noHash.replace(/\/+$/, "").replace(/^\/+/, "");
}

const here = norm(currentPath);

function isActive(href: string): boolean {
  if (href.startsWith("#") || href.startsWith("http")) return false;
  const target = norm(href);
  if (target === "" && (here === "" || here === "index")) return true;
  return here === target;
}
---

<aside
  class:list={[
    "fixed top-12 bottom-0 left-0 w-[260px] pb-6 px-5 z-20 overflow-y-auto border-r border-warm-white",
    className,
  ]}
>
  {brand && (
    <a
      href={withBase(brandHref)}
      class="font-display text-3xl tracking-tight text-charcoal block mb-10 leading-none"
    >
      {brand}
    </a>
  )}

  {items.length > 0 && (
    <nav class="space-y-0.5 text-sm">
      {items.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={withBase(item.href)}
            class:list={["nav-item", active && "font-medium"]}
            aria-current={active ? "page" : undefined}
          >
            {item.icon && (
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 opacity-80"
                set:html={item.icon}
              />
            )}
            <span>{item.label}</span>
            {active && (
              <span class="ml-auto size-1.5 rounded-full bg-accent" aria-hidden="true" />
            )}
          </a>
        );
      })}
    </nav>
  )}

  <slot />
</aside>
