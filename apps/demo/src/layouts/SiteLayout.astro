---
import { BaseLayout } from "@pressmark/astro";
import DemoSidebar from "../components/DemoSidebar.astro";
import "../styles/main.css";

type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props as Props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <DemoSidebar slot="sidebar" currentPath={currentPath} />
  <slot />
</BaseLayout>
